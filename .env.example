# Backend Configuration
BACKEND_PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kysb_fitness
DB_USER=postgres
DB_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@kysbfitness.com
SMTP_FROM_NAME=KYSB Fitness Center

# Frontend Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_APP_NAME=KYSB Fitness Center

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Admin Email
ADMIN_EMAIL=admin@kysbfitness.com

# Cron Configuration
CRON_EMAIL_REMINDER_ENABLED=true
CRON_EMAIL_REMINDER_TIME=0 9 * * *
